<%- layout("/layouts/bolierplayte") %>

<div class="row mt-3">

    <div class="card col-6 offset-3 listing-card">
<div class="col-l-12  col-md-6 col-lg-8 ">
        <h2>Room Details:</h2>
    </div>

    <p class="col-l-12  col-md-6 col-lg-8 ">
        <b>Hostel Name:</b> <%= room.title %>
    </p>
        <!-- Carousel -->
        <div id="roomCarousel" class="carousel slide" data-bs-ride="carousel">

            <div class="carousel-inner">
                <% room.image.forEach((img, index) => { %>
                    <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                        <img class="d-block w-100"
                             src="<%= img.url %>"
                             style="max-height: 450px; object-fit: cover;">
                    </div>
                <% }); %>
            </div>

            <% if (room.image.length > 1) { %>
            <button class="carousel-control-prev" type="button"
                    data-bs-target="#roomCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>

            <button class="carousel-control-next" type="button"
                    data-bs-target="#roomCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>
            <% } %>

        </div>

        <!-- Room Info -->
        <div class="card-body">
            <p><b>Owner:</b> <%= room.owner.username %></p>
            <p><b>City:</b> <%= room.city %></p>
            <p><b>Area:</b> <%= room.area %></p>
            <p><b>Type:</b> <%= room.category %></p>
            <p><b>Room Type:</b> <%= room.roomType %></p>
            <p><b>Gender:</b> <%= room.gender %></p>
            <p><b>Facilities:</b> <%= room.facilities %></p>
            <p><b>Rent:</b> <%= room.price.toLocaleString() %> RS</p>
        </div>

    </div>
</div>

<!-- Booking Button -->
<a href="/Rooms/<%= room._id %>/booking"
   class="btn btn-primary col-2  offset-3 mb-3 booked-btn">
   Book This Room
</a>

<!-- Owner Actions -->
<% if(currentUser && room.owner._id.equals(currentUser._id)) { %>
<div class="btns mb-3">

    <a href="/Rooms/<%= room._id %>/edit"
       class="btn btn-dark col-1 offset-3">
        Edit
    </a>

    <form method="POST"
          action="/Rooms/<%= room._id %>?_method=DELETE"
          style="display:inline;">
        <button type="submit" class="btn btn-dark">
            Delete
        </button>
    </form>
   

</div>
<% } %>
  <!-- Back Button (FIXED POSITION) -->
    <button type="button"
            onclick="history.back()"
            class="btn btn-secondary  offset-3">
           Back
    </button>

<!-- Review Form -->
<div class="col-8 offset-3" >

    <% if(currentUser){ %>
    <h3>Leave a Review</h3>

    <form method="POST"
          action="/Rooms/<%= room._id %>/reviews"
          class="needs-validation">

        <div class="mb-3 mt-3">

            <label class="form-label">Rating</label>

            <fieldset class="starability-basic">

                <fieldset class="starability-basic">

    <input type="radio" id="first-rate1"
           name="review[rating]" value="1" />
    <label for="first-rate1" title="Terrible">1 star</label>

    <input type="radio" id="first-rate2"
           name="review[rating]" value="2" />
    <label for="first-rate2" title="Not good">2 stars</label>

    <input type="radio" id="first-rate3"
           name="review[rating]" value="3" />
    <label for="first-rate3" title="Average">3 stars</label>

    <input type="radio" id="first-rate4"
           name="review[rating]" value="4" />
    <label for="first-rate4" title="Very good">4 stars</label>

    <input type="radio" id="first-rate5"
           name="review[rating]" value="5" />
    <label for="first-rate5" title="Amazing">5 stars</label>



            </fieldset>
        </div>

        <div class="mb-3">
            <label>Comment</label>
            <textarea name="review[comment]"
                      rows="4"
                      class="form-control"
                      required></textarea>
        </div>

        <button class="btn btn-outline-dark mb-3">
            Submit
        </button>

    </form>
    <% } %>

   

    <!-- Reviews -->
    <div class="row">

        <% if(room.reviews && room.reviews.length > 0){ %>

            <% for(let review of room.reviews){ %>

            <div class="card col-6 mb-3 review-card">

                <div class="card-body">
                    <h5><%= review.author.username %></h5>

                    <p class="starability-result"
                       data-rating="<%= review.rating %>"></p>

                    <p><%= review.comment %></p>
                </div>

                <form method="POST"
                      action="/Rooms/<%= room._id %>/reviews/<%= review._id %>?_method=DELETE">
                    <button class="btn btn-sm btn-dark mb-3">
                        Delete
                    </button>
                </form>
            </div>

            <% } %>
        <% } else { %>
            <p>No reviews yet</p>
        <% } %>

    </div>

</div>